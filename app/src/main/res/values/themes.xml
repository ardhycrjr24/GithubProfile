<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Theme utama aplikasi (ADA ACTION BAR) -->
    <style name="Theme.GithubProfile" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- warna primary (bar atas) -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
    </style>

    <!-- Splash Screen Style (FULLSCREEN TANPA BAR) -->
    <style name="SplashScreenStyle" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

</resources>